# ===========================================
# POOKIEPING - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# ===========================================
# DATABASE
# ===========================================
# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/xss-playground

# MongoDB Atlas (uncomment and replace with your connection string):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/xss-playground?retryWrites=true&w=majority

# ===========================================
# JWT SECRET
# ===========================================
# Change this to a long random string in production!
JWT_SECRET=xss-playground-secret-key-change-me-in-production

# ===========================================
# SERVER
# ===========================================
PORT=5000
